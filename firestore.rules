rules_version = '2';

// ═══════════════════════════════════════════════════════════════
//  Auricélia Transportes · Central Financeira
//  Regras de segurança do Firestore
//
//  Princípio: o PAPEL vem do custom claim (carimbado pelo script
//  definir-papeis.js). O usuário não consegue alterar o próprio papel,
//  nem pelo sistema, nem pelo console.
//
//  Como publicar: Firebase → Firestore Database → aba "Rules" →
//  cole este conteúdo → botão "Publish".
// ═══════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funções auxiliares ──────────────────────────────────
    function autenticado() {
      return request.auth != null;
    }

    function papel() {
      return request.auth.token.role;
    }

    // Gestão = quem enxerga e altera a empresa toda
    function gestao() {
      return autenticado() && papel() in ['gestor', 'operacional', 'dona'];
    }

    // Gestor administrador = poderes máximos (apagar tudo, etc.)
    function gestor() {
      return autenticado() && papel() == 'gestor';
    }

    // Dono do lançamento (o operador que o registrou)
    function meuRegistro() {
      return autenticado() && resource.data.byId == request.auth.uid;
    }

    // ── CADASTROS (usuários, caixas, contas, categorias, orçamentos…) ──
    // Todos leem (o sistema precisa saber quem é quem).
    // Só a gestão altera. Um operador de caixa não consegue se promover,
    // criar usuários, nem mexer em contas bancárias.
    match /auricelia/{documento} {
      allow read:  if autenticado();
      allow write: if gestao();
    }

    // ── LANÇAMENTOS DO FLUXO DE CAIXA ──────────────────────
    // Qualquer usuário autenticado registra lançamentos.
    // Alterar ou apagar: só a gestão, ou o próprio autor do lançamento.
    match /auricelia_flux/{id} {
      allow read:   if autenticado();
      allow create: if autenticado();
      allow update, delete: if gestao() || meuRegistro();
    }

    // ── CONTAS A RECEBER / A PAGAR / BOLETOS ───────────────
    // Área financeira: leitura para todos, escrita só para a gestão.
    match /auricelia_receber/{id} {
      allow read:  if autenticado();
      allow write: if gestao();
    }
    match /auricelia_pagar/{id} {
      allow read:  if autenticado();
      allow write: if gestao();
    }
    match /auricelia_boletos/{id} {
      allow read:  if autenticado();
      allow write: if gestao();
    }

    // ── HISTÓRICO (trilha de auditoria) ────────────────────
    // Qualquer um acrescenta a sua própria linha; ninguém edita o passado.
    // Só o gestor administrador pode apagar registros antigos.
    match /auricelia_hist/{id} {
      allow read:   if autenticado();
      allow create: if autenticado();
      allow update: if false;          // histórico não se reescreve
      allow delete: if gestor();
    }

    // ── COMPROVANTES ANEXADOS ──────────────────────────────
    match /auricelia_anexos/{id} {
      allow read:   if autenticado();
      allow create: if autenticado();
      allow update: if gestao();
      allow delete: if gestao();
    }

    // ── Nada mais é acessível ──────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
